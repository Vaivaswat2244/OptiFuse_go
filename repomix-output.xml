<file path="proto/graph.proto">
syntax = "proto3";

package optifuse.graph.v1;
option go_package = "github.com/Vaivaswat2244/OptiFuse_go/proto;proto";

// ─────────────────────────────────────────────
// Core domain types — translated from structures.py
// ─────────────────────────────────────────────

// Corresponds to LambdaFunction in structures.py.
// Fields are split into two groups:
//   - Static: sourced from serverless.yml by the parser service
//   - Telemetry: filled in by the enricher service (zero value = not yet enriched)
message FunctionNode {
  // ── Static fields (from YAML) ──────────────────────────────────────────────
  string id             = 1;  // unique key within the application, e.g. "resize"
  string name           = 2;  // human-readable, same as id for now
  int32  memory_mb      = 3;  // memorySize from YAML or provider default
  int32  timeout_sec    = 4;  // timeout in seconds
  string handler        = 5;  // e.g. "src/resize.handler"
  string runtime        = 6;  // e.g. "nodejs18.x"
  map<string, string> environment = 7;

  // data_out_bytes: maps child function ID → bytes transferred on that edge
  // Corresponds to LambdaFunction.data_out_edges in structures.py
  map<string, int64> data_out_bytes = 8;

  // load_factor: multiplier on baseline_runtime. Default 1.0.
  // Preserved from structures.py to support simulation mode.
  double load_factor = 9;

  // ── Telemetry fields (from enricher / CloudWatch) ─────────────────────────
  // Zero value means "not yet enriched" — all algorithms must handle this gracefully.
  double avg_duration_ms    = 20;
  double avg_memory_used_mb = 21;
  int64  invocation_count   = 22;
  double error_rate         = 23;
  double p99_latency_ms     = 24;
  double cold_start_rate    = 25;
}

// Directed edge between two function nodes.
// The weight is the data transfer cost in USD (pre-computed from data_out_bytes).
// Kept separate from FunctionNode.data_out_bytes so graph algorithms can
// work with a simple edge list without dereferencing node maps.
message Edge {
  string from   = 1;  // parent function ID
  string to     = 2;  // child function ID
  int64  data_bytes = 3;  // raw bytes transferred
  double cost_usd   = 4;  // (data_bytes / GiB) * $0.01 — pre-computed by parser
}

// Constraints on the application — from the custom.optifuse block in serverless.yml.
// Corresponds to the constraint fields on Application in structures.py.
message Constraints {
  int32  max_memory_mb     = 1;  // default 1024
  int32  max_latency_ms    = 2;  // default 30000
  int32  network_hop_ms    = 3;  // default 20 — latency added per cross-group call
}

// The full application graph.
// Corresponds to Application in structures.py.
message Graph {
  string      name              = 1;
  map<string, FunctionNode> nodes = 2;  // keyed by function ID
  repeated Edge edges           = 3;
  repeated string critical_path = 4;   // ordered list of function IDs
  Constraints constraints       = 5;
}
</file>

<file path="proto/optimizer.proto">
syntax = "proto3";

package optifuse.optimizer.v1;
option go_package = "github.com/Vaivaswat2244/OptiFuse_go/proto;proto";

import "proto/graph.proto";

// ─────────────────────────────────────────────
// Optimizer service request / response types
// ─────────────────────────────────────────────

// Which algorithm(s) to run. Matches the 5 Python implementations exactly.
enum Algorithm {
  ALGORITHM_UNSPECIFIED    = 0;
  ALGORITHM_NO_FUSION      = 1;  // no_fusion      — baseline, each func is its own group
  ALGORITHM_SINGLETON      = 2;  // singleton      — all funcs in one group (BFS order)
  ALGORITHM_MIN_W_CUT      = 3;  // min_w_cut_heuristic
  ALGORITHM_GREEDY_TP      = 4;  // greedy_tree_partitioning
  ALGORITHM_COSTLESS_CSP   = 5;  // costless_csp   — Pareto-optimal label-setting on critical path
  ALGORITHM_MTX_ILP        = 6;  // mtx_ilp        — optimal ILP (slow, use with caution)
  ALGORITHM_ALL            = 7;  // run all 6 and return all results
}

// A single fused deployment group — corresponds to CompositeFunction in structures.py.
// Contains the IDs of all member functions, plus pre-computed aggregate metrics.
message FusionGroup {
  repeated string function_ids  = 1;  // ordered; first ID is the group's canonical ID
  int32  total_memory_mb        = 2;  // sum of member memory
  int32  total_runtime_ms       = 3;  // sum of member runtimes (sequential execution)
  double execution_cost_usd     = 4;  // (total_memory_mb/1024) * (total_runtime_ms/1000) * 0.00001667
}

// Metrics for a complete partition — corresponds to calculate_metrics() output.
message Metrics {
  double total_cost_usd   = 1;  // execution cost + data transfer cost across all cut edges
  double latency_ms       = 2;  // critical path latency including network hops at cuts
  bool   feasible         = 3;  // true iff memory and latency constraints are satisfied
  double runtime_ms       = 4;  // wall-clock time the algorithm itself took
}

// Result from a single algorithm run.
message AlgorithmResult {
  string    name          = 1;  // human-readable algo name, e.g. "Greedy TP (GrTP)"
  Algorithm algorithm     = 2;
  repeated FusionGroup groups = 3;
  Metrics   metrics       = 4;
  bool      error         = 5;
  string    error_message = 6;
}

// The full optimization plan returned by the optimizer service.
// Contains results from all requested algorithms so the frontend
// can display a comparison table.
message OptimizationPlan {
  repeated AlgorithmResult results = 1;
  // The recommended result — lowest cost among feasible solutions.
  // Empty if no feasible solution was found.
  AlgorithmResult recommended = 2;
}

// ─────────────────────────────────────────────
// gRPC service definition
// ─────────────────────────────────────────────

message OptimizeRequest {
  optifuse.graph.v1.Graph graph = 1;
  repeated Algorithm algorithms = 2;  // if empty, runs ALGORITHM_ALL
}

message OptimizeResponse {
  OptimizationPlan plan = 1;
}

service OptimizerService {
  // Synchronous — runs all requested algorithms and returns.
  // For ILP on large graphs this can be slow; the gateway should set a long timeout.
  rpc Optimize(OptimizeRequest) returns (OptimizeResponse);
}
</file>

<file path="proto/services.proto">
syntax = "proto3";

package optifuse.services.v1;
option go_package = "github.com/Vaivaswat2244/OptiFuse_go/proto;proto";

import "proto/graph.proto";
import "proto/optimizer.proto";

// ─────────────────────────────────────────────
// Parser service
// Translates a raw serverless.yml into a Graph.
// No AWS credentials required — purely stateless.
// ─────────────────────────────────────────────

message ParseRequest {
  string repo_name    = 1;
  bytes  yaml_content = 2;  // raw serverless.yml bytes
}

message ParseResponse {
  optifuse.graph.v1.Graph graph = 1;
  repeated string warnings      = 2;  // non-fatal issues (e.g. missing topology block)
}

service ParserService {
  rpc Parse(ParseRequest) returns (ParseResponse);
}

// ─────────────────────────────────────────────
// Enricher service
// Takes a Graph from the parser and fills in telemetry fields
// by querying CloudWatch Logs Insights.
// Requires AWS read credentials (passed as assumed-role ARN).
// ─────────────────────────────────────────────

message EnrichRequest {
  optifuse.graph.v1.Graph graph = 1;

  // AWS assume-role parameters — corresponds to get_assumed_role_session() in aws.py
  string role_arn    = 2;  // e.g. "arn:aws:iam::123456789012:role/OptifuseReader"
  string external_id = 3;

  // Serverless Framework deployment identifiers — needed to build log group names:
  // /aws/lambda/{service_name}-{stage}-{function_id}
  string service_name = 4;
  string stage        = 5;

  // How far back to query. Defaults to 24h if zero.
  int32  lookback_hours = 6;
}

message EnrichResponse {
  optifuse.graph.v1.Graph graph = 1;  // same graph, telemetry fields now populated
  repeated string enriched_ids  = 2;  // function IDs that had CloudWatch data
  repeated string missing_ids   = 3;  // function IDs with no log data found
}

service EnricherService {
  rpc Enrich(EnrichRequest) returns (EnrichResponse);
}

// ─────────────────────────────────────────────
// Deployer service
// Takes the original YAML + an OptimizationPlan,
// emits an optimized serverless.yml, and optionally deploys it.
// Requires AWS write credentials.
// ─────────────────────────────────────────────

message DeployRequest {
  bytes  original_yaml_content    = 1;  // the original serverless.yml bytes
  optifuse.optimizer.v1.AlgorithmResult result = 2;  // the chosen fusion plan

  // AWS credentials for deployment
  string role_arn    = 3;
  string external_id = 4;
  string region      = 5;

  // If false: only generate the optimized YAML, don't actually deploy.
  // If true: generate + run `serverless deploy`.
  bool   deploy_live = 6;
}

message DeployResponse {
  bytes  optimized_yaml  = 1;  // the generated serverless.yml bytes
  bool   deployed        = 2;  // true if deploy_live was true and succeeded
  string deploy_log      = 3;  // stdout/stderr from the deploy command
  string error           = 4;
}

service DeployerService {
  rpc Deploy(DeployRequest) returns (DeployResponse);
}
